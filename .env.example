# Variaveis de ambiente lidas pelo docker-compose.
#
# Em desenvolvimento local com Docker, apenas JWT_SECRET e necessario.
# As credenciais do banco (postgres) sao definidas de forma fixa em
# docker-compose.yml: banco local efemero em container, sem segredos.
#
# Para gerar um JWT_SECRET aleatorio com 128 caracteres:
#   openssl rand -hex 64

JWT_SECRET=
JWT_EXPIRATION_MS=86400000
